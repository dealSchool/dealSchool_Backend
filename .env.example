# Copy this file to .env.local and fill in your values
# .env.local is gitignored — never commit it

# ── Cashfree ──────────────────────────────────────────────────────────────────
# Which credential pair is actually used (sandbox vs live) is controlled at
# runtime via the "settings/payment" Firestore doc — switch it with
# GET/PATCH /settings/payment (admin-only). Both pairs must be set here so the
# app can switch without a redeploy; whichever one isn't currently selected is
# simply unused. Defaults to sandbox if the Firestore doc doesn't exist yet.
CASHFREE_APP_ID_SANDBOX=TEST10xxxxxxxxxxxxxxxxxxxxxxxxxxx
CASHFREE_SECRET_KEY_SANDBOX=cfsk_ma_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CASHFREE_APP_ID_LIVE=your_live_app_id
CASHFREE_SECRET_KEY_LIVE=cfsk_ma_prod_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Fellowship fee in rupees — 1000 = ₹1000 payment link
FELLOWSHIP_FEE=1000

# ── App URL (Cashfree redirects here after payment) ───────────────────────────
APP_BASE_URL=http://localhost:3000

# ── Email (Nodemailer / Google Workspace SMTP) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_smtp_app_password
ADMIN_EMAIL=admin@yourdomain.com

# ── CORS — comma-separated list of allowed frontend origins ───────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Firebase Web API Key (for admin login via REST) ───────────────────────────
FIREBASE_WEB_API_KEY=your_firebase_web_api_key

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
